# Runtime needs no env vars — interview voice uses bundled MP3s in public/audio/interviews/.

# Optional: only if you regenerate clips with npm run generate-interview-audio
# Copy these to .env.local (never commit .env.local):
# VITE_ELEVENLABS_API_KEY=
# VITE_ELEVENLABS_VOICE_GRANT=
# VITE_ELEVENLABS_VOICE_PATEL=
# VITE_ELEVENLABS_MODEL=
